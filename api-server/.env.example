# Supabase dashboard → Settings → General → Project ID → https://<ref>.supabase.co
SUPABASE_URL=

# Supabase dashboard → Settings → API Keys → Publishable Key (sb_secret_xxx)
SUPABASE_SERVICE_ROLE_KEY=

# Your own secret shared with Colyseus for JWT signing/verification
# Generate with: openssl rand -base64 32
JWT_SECRET=

# Supabase dashboard → Connect → Direct connection (port 5432)                                                                       
DATABASE_URL=

# Must match game-server INTERNAL_SECRET
# openssl rand -base64 32
INTERNAL_SECRET=

PORT=3000
